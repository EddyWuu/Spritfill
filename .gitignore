# macOS system files
.DS_Store

# Xcode user-specific files (per-user settings, breakpoints, etc.)
xcuserdata/
*.xcuserstate
IDEWorkspaceChecks.plist

# Xcode build artifacts
DerivedData/
build/
*.build/

# CocoaPods
Pods/

# Swift Package Manager
.swiftpm/
Package.resolved

# Carthage
Carthage/Build

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots

# General logs
*.log

# Temporary files
tmp/

# Firebase config (contains API keys - do not push to public repos)
GoogleService-Info.plist
serviceAccountKey.json

# Server temp files
Server/temp/

# StoreKit config (contains internal IDs, recreate via Xcode)
*.storekit
